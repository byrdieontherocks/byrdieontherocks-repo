	<script>
		// Show back to top button on scroll
		window.onscroll = function () {
			let button = document.getElementById("backToTop");
			if (document.documentElement.scrollTop > 200) {
				button.style.display = "block";
			} else {
				button.style.display = "none";
			}
		};

		// Scroll to top function
		document.getElementById("backToTop").addEventListener("click", function () {
			window.scrollTo({ top: 0, behavior: 'smooth' });
		});

		// Disclaimer popup logic (the other popup)
		window.onload = function () {
			const disclaimerPopup = document.getElementById('popup');
			const closeDisclaimerBtn = document.getElementById('close-btn');

			if (closeDisclaimerBtn) {
				closeDisclaimerBtn.addEventListener('click', function () {
					disclaimerPopup.style.display = 'none';
				});
			}

			const continueBtn = document.getElementById('continue-btn');
			if (continueBtn) {
				continueBtn.onclick = function () {
					disclaimerPopup.style.display = 'none';
				};
			}
		};

		// Read more popup 
		const readMorePopup = document.getElementById('popupBox');
		const closeReadMoreBtn = document.getElementById('closePopup');
		const triggerLink = document.getElementById('klLink');

		let popupClosed = false;   // tracks manual or auto close
		let popupShown = false;    // Run auto-close only once

		// Show popup when link is fully in view
		window.addEventListener('scroll', () => {
			if (popupClosed || popupShown) return;          // do nothing if already closed 
			if (!readMorePopup || !triggerLink) return;     // safety check

			const rect = triggerLink.getBoundingClientRect();
			const fullyVisible = rect.top >= 0 && rect.bottom <= window.innerHeight;

			if (fullyVisible) {
				readMorePopup.style.display = 'block';
				popupShown = true;                            // remember we have displayed it once

				// Auto-close after 3 seconds
				setTimeout(() => {
					readMorePopup.style.display = 'none';
					popupClosed = true;                         // stop future popups
				}, 3000);
			}
		});

		// Manual close button for KL popup
		if (closeReadMoreBtn) {
			closeReadMoreBtn.addEventListener('click', () => {
				readMorePopup.style.display = 'none';
				popupClosed = true;   // stop future popups
			});
		}

		// ================================
		// popup logic (new popup)
		const taiwanPopup = document.getElementById('popupBoxTaiwan');
		const closeTaiwanBtn = document.getElementById('closePopupTaiwan');
		const taiwanTriggerLink = document.getElementById('taiwanLink');

		let taiwanPopupClosed = false;
		let taiwanPopupShown = false;

		window.addEventListener('scroll', () => {
			if (taiwanPopupClosed || taiwanPopupShown) return;
			if (!taiwanPopup || !taiwanTriggerLink) return;

			const rect = taiwanTriggerLink.getBoundingClientRect();
			const fullyVisible = rect.top >= 0 && rect.bottom <= window.innerHeight;

			if (fullyVisible) {
				taiwanPopup.style.display = 'block';
				taiwanPopupShown = true;

				setTimeout(() => {
					taiwanPopup.style.display = 'none';
					taiwanPopupClosed = true;
				}, 4000);
			}
		});

		if (closeTaiwanBtn) {
			closeTaiwanBtn.addEventListener('click', () => {
				taiwanPopup.style.display = 'none';
				taiwanPopupClosed = true;
			});
		}
	</script>

